---
layout: bare
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign pages = site.html_pages | sort: 'url' %}
{% for p in pages %}
  {% unless p.url contains '/404.html' %}
  <url>
    <loc>{{ p.url | absolute_url }}</loc>
  </url>
  {% endunless %}
{% endfor %}
</urlset>
